# ============================================================
# LINHA RETA TURISMO — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha os valores
# NUNCA faça commit do .env.local no GitHub
# ============================================================

# --- Supabase ---
# Encontre em: supabase.com → seu projeto → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key_aqui
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui

# --- Resend (email marketing + transacional) ---
# Encontre em: resend.com → API Keys
RESEND_API_KEY=re_sua_chave_aqui
RESEND_FROM_EMAIL=contato@linharetaturismo.com.br
RESEND_FROM_NAME=Linha Reta Turismo

# --- Claude API (IA para blog) ---
# Encontre em: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-sua_chave_aqui

# --- WhatsApp ---
NEXT_PUBLIC_WHATSAPP_NUMBER=5581912181781
NEXT_PUBLIC_WHATSAPP_DEFAULT_MSG=Olá! Vim pelo site e tenho interesse em saber mais sobre os pacotes.

# --- Site ---
NEXT_PUBLIC_SITE_URL=https://linharetaturismo.com.br
NEXT_PUBLIC_SITE_NAME=Linha Reta Turismo

# --- Admin (email do dono para login) ---
ADMIN_EMAIL=seu@email.com
